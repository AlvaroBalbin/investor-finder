# investor-finder environment template
# Copy to `.env` and fill in. Never commit your real .env.
#
# If you keep this next to a sibling `thescraper/` checkout, missing keys are
# read from ../thescraper/.env automatically. For a standalone run, just fill
# in what you have below.

# Google search (firm discovery + LinkedIn resolution).
# Either of these works; Serper is primary, Piloterr is the fallback search.
SERPER_API_KEY=
PILOTERR_API_KEY=

# LinkedIn / people enrichment (optional boosters).
CORESIGNAL_API_KEY=
ENRICHLAYER_API_KEY=

# LLM (candidate generation + classification + extraction).
# OpenAI primary; Grok used if OpenAI absent.
OPENAI_API_KEY=
XAI_API_KEY=

# Publish the result to Notion (optional).
NOTION_TOKEN=
# Parent page under which to create the results table.
NOTION_PARENT_PAGE_ID=

# Your company, used only to draft per-fund outreach angles in fit.py (optional).
COMPANY_NAME=
# 2-3 sentences: what you build, sector + business model, what you are raising.
COMPANY_PITCH=

# Contact address sent in the SEC EDGAR request header (SEC asks for a real one).
SEC_CONTACT_EMAIL=
